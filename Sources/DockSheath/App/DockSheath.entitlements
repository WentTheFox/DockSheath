<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	Deliberately no com.apple.security.app-sandbox key: DockSheath must run
	unsandboxed to use the Accessibility API against other processes' windows.
	This rules out Mac App Store distribution, which is expected — DockSheath
	ships via GitHub Releases only.
	-->
</dict>
</plist>
