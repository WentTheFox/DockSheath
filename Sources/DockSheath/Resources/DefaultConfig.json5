// DockSheath configuration
//
// This file supports the full JSON5 spec (https://spec.json5.org): comments
// like this one, trailing commas, unquoted keys, single-quoted strings, and
// more.
//
// DockSheath watches this file and reloads it automatically whenever you
// save changes — no need to restart the app.
{
  "schemaVersion": 1,

  // Apps pinned to the quick-launch strip. Add entries by dragging an app
  // onto the taskbar, or by hand-editing this list.
  "pinnedApps": [
    // { "bundlePath": "/Applications/Safari.app", "bundleIdentifier": "com.apple.Safari" },
  ],

  // Apps shown in the Quick Launch menu (the Start button's dropdown).
  // Separate from pinnedApps above — favoriting an app here doesn't add it to
  // the taskbar strip, and vice versa. Add entries via "Pin to Quick Launch"
  // on a running app's right-click menu, the Pinned Apps tab in Settings, or
  // by hand-editing this list.
  "quickLaunchFavorites": [
    // { "bundlePath": "/Applications/Safari.app", "bundleIdentifier": "com.apple.Safari" },
  ],

  "taskbar": {
    // DockSheath follows the real Dock to whichever edge of the screen it's
    // on (bottom, left, or right). Leave sizeOverride as null to auto-detect
    // the taskbar's thickness (height at the bottom, width on the side)
    // from the system Dock's reserved screen space. Only set this if you
    // want to override that detection.
    "sizeOverride": null,
  },

  "hotkeys": {
    // Global shortcut to show/hide the taskbar (revealing the real Dock
    // underneath). Default: Command+Option+D.
    "toggleVisibility": { "keyCode": 2, "modifiers": ["command", "option"] },
  },

  "behavior": {
    // Also render a taskbar on every connected screen besides the one the
    // real Dock is on. Those screens have no OS-level space reservation of
    // their own, so DockSheath actively watches for windows that drift
    // under its taskbar there and pulls them back above it.
    "showOnAllDisplays": false,
    // true: one taskbar button per app, covering all of its windows.
    // false: one button per individual window, each with its own title.
    "groupWindowsByApp": true,
    "refreshIntervalMs": 1500,
  },

  "appearance": {
    "theme": "auto", // "auto" | "light" | "dark"
    "accentColor": null, // e.g. "#FF6600" — used for the running-app highlight tint
    "iconSize": 32,
    // Shows a text label under each taskbar button — for running windows,
    // that's the window's title (or "AppName (N)" when an app has multiple
    // windows; hover to see each window's title in the tooltip).
    "showAppLabels": true,

    // Colors for the taskbar's own background/border. Hex strings only
    // ("#RGB", "#RRGGBB", or "#RRGGBBAA"); leave a field null to follow the
    // system light/dark appearance instead of a fixed color.
    "taskbarColors": {
      "background": null,
      "border": null,
    },

    // Colors for the taskbar buttons (Quick Launch, pinned apps, running
    // windows). Same hex format and null-means-system-default rules apply.
    // "text" is also used for the display-number indicator and clock below.
    "buttonColors": {
      "background": null,
      "border": null,
      "text": null,
    },

    // Shows a small badge with the display's number (1, 2, 3, ...) at the
    // trailing edge of its taskbar — the position matches NSScreen.screens
    // order, which is usually the order shown in System Settings > Displays.
    // Handy for telling secondary-display taskbars apart at a glance.
    "showDisplayNumber": false,

    // An optional clock shown next to the display-number badge.
    "clock": {
      "enabled": false,
      // Format string using DateFormatter's pattern syntax (Unicode TR35),
      // e.g.:
      //   "h:mm a"        -> "3:45 PM"
      //   "HH:mm"         -> "15:45"
      //   "h:mm a EEE"    -> "3:45 PM Tue"
      //   "M/d/yy h:mm a" -> "7/3/26 3:45 PM"
      "format": "h:mm a",
    },

    // Fonts for taskbar buttons, the display-number badge, and the clock,
    // independent of each other and of the taskbar's own thickness
    // (taskbar.sizeOverride above). "family" is a font *family* name (e.g.
    // "Avenir Next"), not a PostScript name; null, omitted, or an
    // unrecognized family all fall back to the system font. Each element's
    // font weight is fixed and not configurable here.
    // "buttonFont": { "family": "Menlo", "size": 11 },
    // "displayNumberFont": { "family": "Menlo", "size": 10 },
    // "clockFont": { "family": "Menlo", "size": 11 },
  },

  // Checks whether this app's git clone (see repositoryPath) has new commits
  // on its remote-tracking branch, and offers an "Update & Restart…" action
  // from the Quick Launch and status bar menus when it does. This only
  // *checks* — the actual update still runs Scripts/update.sh interactively
  // in your default terminal app, since that script needs your input (a
  // code-signing trust prompt, and possibly your password).
  "updateCheck": {
    // Run the check automatically at launch (and whenever this file
    // reloads). "Check for Updates…" in the menus/Settings always works
    // regardless of this.
    "checkForUpdates": false,
    // Absolute path to the git clone DockSheath was built from (NOT the
    // installed .app — e.g. "/Users/you/dev/DockSheath"). Leave null to
    // default to the folder DockSheath is currently running from, when
    // that's inside a git checkout (true right after Scripts/build_app.sh,
    // before update.sh moves the app to /Applications) — set this by hand,
    // or via Settings > General's folder picker, if that guess doesn't
    // apply to your setup.
    "repositoryPath": null,
  },

  // Overrides applied only to taskbars on secondary displays (any screen
  // besides the one the real Dock is on — see behavior.showOnAllDisplays).
  // Any field left null/omitted here falls back to the matching field in
  // "taskbar"/"appearance" above, so you only need to list what should
  // differ. The primary display's taskbar always uses "taskbar"/
  // "appearance" directly and ignores this section.
  "secondaryDisplay": {
    "taskbar": {
      // "sizeOverride": 40,
    },
    "appearance": {
      // "theme": "dark",
      // "accentColor": "#FF6600",
      // "iconSize": 28,
      // "showAppLabels": false,
      // "taskbarColors": { "background": "#1E1E1E", "border": null },
      // "buttonColors": { "background": null, "border": null, "text": null },
      // "showDisplayNumber": true,
      // "clock": { "enabled": true, "format": "HH:mm" },
      // "buttonFont": { "family": "Menlo", "size": 11 },
      // "displayNumberFont": { "family": "Menlo", "size": 10 },
      // "clockFont": { "family": "Menlo", "size": 11 },
    },
  },
}
