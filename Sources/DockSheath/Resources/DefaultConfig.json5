// DockSheath configuration
//
// This file supports the full JSON5 spec (https://spec.json5.org): comments
// like this one, trailing commas, unquoted keys, single-quoted strings, and
// more.
//
// DockSheath watches this file and reloads it automatically whenever you
// save changes — no need to restart the app.
{
  "schemaVersion": 1,

  // Apps pinned to the quick-launch strip. Add entries by dragging an app
  // onto the taskbar, or by hand-editing this list.
  "pinnedApps": [
    // { "bundlePath": "/Applications/Safari.app", "bundleIdentifier": "com.apple.Safari" },
  ],

  "taskbar": {
    // DockSheath follows the real Dock to whichever edge of the screen it's
    // on (bottom, left, or right). Leave sizeOverride as null to auto-detect
    // the taskbar's thickness (height at the bottom, width on the side)
    // from the system Dock's reserved screen space. Only set this if you
    // want to override that detection.
    "sizeOverride": null,
  },

  "hotkeys": {
    // Global shortcut to show/hide the taskbar (revealing the real Dock
    // underneath). Default: Command+Option+D.
    "toggleVisibility": { "keyCode": 2, "modifiers": ["command", "option"] },
  },

  "behavior": {
    "autoHideOnMouseLeave": false,
    "showOnAllDisplays": false,
    "groupWindowsByApp": true,
    "refreshIntervalMs": 1500,
  },

  "appearance": {
    "theme": "auto", // "auto" | "light" | "dark"
    "accentColor": null,
    "iconSize": 32,
    "showAppLabels": false,
  },
}
